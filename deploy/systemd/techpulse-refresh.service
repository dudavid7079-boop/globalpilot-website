[Unit]
Description=TechPulse daily topic refresh
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
User=daviddu
SupplementaryGroups=docker
WorkingDirectory=/opt/globalpilot
Environment=APP_DIR=/opt/globalpilot
Environment=RSS_RECENT_HOURS=168
ExecStart=/bin/sh /opt/globalpilot/deploy/techpulse-refresh.sh
