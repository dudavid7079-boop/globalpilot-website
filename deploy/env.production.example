NEXT_PUBLIC_SITE_URL=https://globalpilot.attodigitalhk.com
NEXT_PUBLIC_CONTACT_EMAIL=hello@globalpilot.attodigitalhk.com

# 可选：Umami 访问统计。创建 Umami 网站后填写。
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.globalpilot.attodigitalhk.com/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# 使用 compose.npm.yml 时生效：
# - Nginx Proxy Manager 和网站容器在同一台机器：保持 127.0.0.1
# - NPM 在另一台机器并通过 FRP/内网访问 VM：改为 0.0.0.0，并在防火墙/FRP 中只放行可信入口
APP_BIND=127.0.0.1
APP_PORT=3000

# Mac mini Ollama。推荐填写 Tailscale IP 或 MagicDNS 主机名。
OLLAMA_BASE_URL=http://100.x.x.x:11434
OLLAMA_MODEL=qwen3:8b

# 可选：Telegram 对话同步。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 仅在 Ollama 前还有鉴权代理时使用。
OLLAMA_AUTH_TOKEN=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
