# 网站正式域名与公开联系邮箱
NEXT_PUBLIC_SITE_URL=https://globalpilot.attodigitalhk.com
NEXT_PUBLIC_CONTACT_EMAIL=hello@globalpilot.attodigitalhk.com

# Mac mini Ollama：局域网模式填写 Mac mini 的固定 IP
OLLAMA_BASE_URL=http://192.168.1.100:11434
OLLAMA_MODEL=qwen3:8b

# 若 Vercel 通过 Cloudflare Access Tunnel 访问 Mac mini，再填写下面两项
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# 若你使用的反向代理采用 Bearer Token，可改用此项
OLLAMA_AUTH_TOKEN=

# Telegram：由 @BotFather 创建 Bot；CHAT_ID 是接收网站对话的私聊或群组 ID
TELEGRAM_BOT_TOKEN=123456:your-bot-token
TELEGRAM_CHAT_ID=123456789
